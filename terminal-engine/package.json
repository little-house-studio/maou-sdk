{
  "name": "@little-house-studio/terminal-engine",
  "version": "0.1.0",
  "description": "高性能终端引擎 — Rust + napi-rs",
  "type": "module",
  "main": "./terminal_engine.js",
  "types": "./terminal_engine.d.ts",
  "napi": {
    "name": "terminal-engine",
    "triples": {
      "defaults": true
    }
  },
  "scripts": {
    "build": "napi build --release --platform",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "files": [
    "*.node",
    "*.d.ts",
    "terminal_engine.js"
  ],
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^3.7.3"
  }
}
