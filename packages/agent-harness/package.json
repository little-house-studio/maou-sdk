{
  "name": "@little-house-studio/agent-harness",
  "version": "0.1.0",
  "description": "Maou SDK Agent 运行时层（注册表/工厂、提示词编译、token 追踪、agent-loop、事件总线、技能、Git 监听、插件基类）",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
