{
  "name": "@little-house-studio/cli",
  "version": "0.1.0",
  "description": "Maou SDK 最小 CLI（对标 pi 的 `pi` 命令）——交互式 agent REPL",
  "type": "module",
  "license": "MIT",
  "bin": {
    "maou": "./dist/index.js"
  },
  "main": "dist/index.js",
