{
  "name": "@little-house-studio/cli",
  "version": "0.2.0",
  "description": "Maou CLI — RPG 风格终端 AI 对话界面（Ink + React）",
  "type": "module",
  "license": "MIT",
  "bin": {
    "maou": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./image": {
      "types": "./dist/image/ascii.d.ts",
      "import": "./dist/image/ascii.js"
    },
    "./canvas": {
      "types": "./dist/canvas/primitives.d.ts",
      "import": "./dist/canvas/primitives.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.tsx",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "dev:demo": "tsx src/demo.tsx",
    "demo": "node dist/demo.js",
    "test:demo": "FORCE_COLOR=3 MAOU_DEMO_TEST=1 tsx scripts/smoke-demo.mjs"
  },
  "dependencies": {
    "@little-house-studio/agent": "workspace:*",
    "@little-house-studio/coding-agent": "workspace:*",
    "@little-house-studio/context": "workspace:*",
    "@little-house-studio/llm": "workspace:*",
    "@little-house-studio/tools": "workspace:*",
    "@little-house-studio/types": "workspace:*",
    "ink": "^5.0.1",
    "react": "^18.2.0",
    "pngjs": "^3.3.3",
    "string-width": "^7.1.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
