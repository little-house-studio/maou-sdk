{
  "name": "@little-house-studio/cli",
  "version": "0.1a",
  "description": "Maou CLI \u2014 \u6781\u7b80\u7ec8\u7aef AI \u5bf9\u8bdd\u754c\u9762",
  "type": "module",
  "license": "MIT",
  "bin": {
    "maou": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-sounds.mjs",
    "build:native": "npm run build --prefix native/term-raster",
    "build:all": "npm run build:native && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "dev:watch": "node scripts/dev-watch.mjs",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "postinstall": "node dist/commands/postinstall.js || exit 0",
    "gallery:bake": "node scripts/bake-gallery-ascii.mjs",
    "build:tui-ratatui": "cargo build --release --manifest-path tui-ratatui/Cargo.toml && node scripts/install-tui-bin.mjs",
    "build:tui-ratatui:debug": "cargo build --manifest-path tui-ratatui/Cargo.toml",
    "install:tui-bin": "node scripts/install-tui-bin.mjs",
    "dev:ratatui": "npm run build:tui-ratatui:debug && tsx src/index.ts coding"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@little-house-studio/agent": "workspace:*",
    "@little-house-studio/coding-agent": "workspace:*",
    "@little-house-studio/context": "workspace:*",
    "@little-house-studio/llm": "workspace:*",
    "@little-house-studio/tools": "workspace:*",
    "@little-house-studio/types": "workspace:*",
    "ansi-escapes": "^7.3.0",
    "cli-highlight": "^2.1.0",
    "diff": "^9.0.0",
    "figures": "^6.1.0",
    "fuse.js": "^7.4.2",
    "marked": "^12.0.0",
    "string-width": "^7.1.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@lydell/node-pty": "1.2.0-beta.12",
    "@types/diff": "^8.0.0",
    "@types/node": "^22.0.0",
    "@xterm/headless": "^6.0.0",
    "node-pty": "^1.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
