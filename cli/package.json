{
  "name": "@little-house-studio/cli",
  "version": "0.3.0",
  "description": "Maou CLI — 极简终端 AI 对话界面",
  "type": "module",
  "license": "MIT",
  "bin": {
    "maou": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-sounds.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.tsx",
    "dev:watch": "node scripts/dev-watch.mjs",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@inkjs/ui": "^2.0.0",
    "@little-house-studio/agent": "workspace:*",
    "@little-house-studio/coding-agent": "workspace:*",
    "@little-house-studio/context": "workspace:*",
    "@little-house-studio/llm": "workspace:*",
    "@little-house-studio/tools": "workspace:*",
    "@little-house-studio/types": "workspace:*",
    "ansi-escapes": "^7.3.0",
    "cli-highlight": "^2.1.0",
    "diff": "^9.0.0",
    "figures": "^6.1.0",
    "fuse.js": "^7.4.2",
    "ink": "^7.0.0",
    "marked": "^12.0.0",
    "react": "^19.0.0",
    "react-ink-textarea": "^0.2.2",
    "string-width": "^7.1.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@lydell/node-pty": "1.2.0-beta.12",
    "@types/diff": "^8.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@xterm/headless": "^6.0.0",
    "ink-testing-library": "^4.0.0",
    "node-pty": "^1.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
