{
  "name": "@little-house-studio/hub",
  "version": "0.1.0",
  "description": "Maou SDK Hub 层（多设备通信中心：设备注册表、事件总线、HTTP 服务、SDK 客户端）",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
