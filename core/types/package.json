    "clean": "rm -rf dist"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
