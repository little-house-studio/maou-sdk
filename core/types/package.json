{
  "name": "@little-house-studio/types",
  "version": "0.1.0",
  "description": "Maou SDK 基础层（共享领域类型 + 应用配置 + ConfigStore/项目管理/工具函数/表情检测）",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
