{
  "name": "@little-house-studio/tools",
  "version": "0.1.0",
  "description": "Maou SDK 工具系统（Tool 抽象基类、注册表、执行器、内置工具集、技能加载）",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
