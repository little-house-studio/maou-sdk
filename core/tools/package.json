    "zod-to-json-schema": "^3.24.6",
    "@little-house-studio/sqry-engine": "workspace:*",
    "@little-house-studio/opencli-engine": "workspace:*",
    "@little-house-studio/lsp-engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
