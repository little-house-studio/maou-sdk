{
  "name": "todo_finish",
  "description": "汇报当前负责的一个 todo 节点完成或失败。一次只代表 task_id 这一个节点。completed 解锁下游；failed 不解锁、不自动失败其它节点。",
  "parameters": {
    "type": "object",
    "properties": {
      "task_id": {
        "type": "string",
        "description": "当前节点 ID"
      },
      "status": {
        "type": "string",
        "enum": ["completed", "failed"],
        "description": "completed=成功 | failed=失败类完成"
      },
      "summary": {
        "type": "string",
        "description": "短说明（做了什么或失败原因摘要）"
      },
      "report": {
        "type": "string",
        "description": "完整交接汇报（链终点或需下游阅读时）"
      },
      "reason": {
        "type": "string",
        "description": "failed 时原因；也可写在 summary"
      }
    },
    "required": ["task_id", "summary"],
    "additionalProperties": false
  }
}
