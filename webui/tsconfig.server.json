{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist/server",
    "rootDir": "src/server",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src/server/**/*"]
}
