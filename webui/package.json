{
  "name": "@little-house-studio/webui",
  "version": "0.1.0",
  "description": "Maou WebUI — chat + embedded terminal (SDK layer)",
  "type": "module",
  "license": "MIT",
  "bin": {
    "maou-web": "./dist/server/cli.js"
  },
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "DESIGN.md"
  ],
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "build": "npm run build:server && npm run build:client",
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/cli.ts",
    "dev:client": "vite",
    "start": "node dist/server/cli.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/view": "^6.36.0",
    "@little-house-studio/agent": "workspace:*",
    "@little-house-studio/coding-agent": "workspace:*",
    "@little-house-studio/terminal-engine": "workspace:*",
    "@little-house-studio/types": "workspace:*",
    "@lydell/node-pty": "1.2.0-beta.12",
    "@uiw/react-codemirror": "^4.23.7",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "express": "^4.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
